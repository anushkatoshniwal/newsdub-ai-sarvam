# Sarvam AI API key — get one at https://dashboard.sarvam.ai
# The SDK reads this automatically when using SarvamAI().
SARVAM_API_KEY=your_sarvam_api_key_here

# Optional: RSS feed URL (defaults to BBC News)
RSS_FEED_URL=http://feeds.bbci.co.uk/news/rss.xml

# Optional Flask settings
FLASK_SECRET_KEY=change-this-to-a-random-secret
FLASK_DEBUG=false
FLASK_PORT=5000
